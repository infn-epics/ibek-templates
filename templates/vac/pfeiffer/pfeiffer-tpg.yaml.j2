
# yaml-language-server: $schema=https://github.com/epics-containers/ibek/releases/download/3.1.2/ibek.support.schema.json
ioc_name: {{iocname}}
description: Pfeiffer TPG Gauge Controllers TEMPLATE

entities:

{%- if devtype == 'tpg300' or devtype == 'tpg500' %}
- type: pfeiffer.{{devtype}}.controller
  name: PFEIFFER_CTRL_PORT
  IP: {{server}}
  TCPPORT: {{port}}
  P: "{{iocprefix}}"
{%- for t in devices %}
- type: pfeiffer.{{devtype}}.channel
  controller: PFEIFFER_CTRL_PORT
  name: "{{ t.name }}"
  channel: {{ t.channel }}
{%- endfor %}
{%- else %}{# tpg366 – one controller per VGC unit, one sensor entity per active channel #}
- type: pfeiffer.tpg366.controller
  name: PFEIFFER_CTRL_PORT
  P: "{{iocprefix}}"
  IP: {{server}}
  TCPPORT: {{port}}
{%- for dev in devices %}
- type: pfeiffer.tpg366.sensor
  controller: PFEIFFER_CTRL_PORT
  name: "{{iocprefix}}:{{ dev.name }}"
  channel: "{{ dev.channel | replace('A', '') }}"
{%- endfor %}
- type: pfeiffer.tpg366.setpoints
  controller: PFEIFFER_CTRL_PORT
{%- endif %}


{%- for dev in devices %}

{%- for param in dev.aliases %}
- type: epics.DbAlias
  name: "{{iocprefix}}:{{dev.name}}:{{param.name}}"
  alias: "{{iocprefix}}:{{dev.name}}:{{param.alias}}"
{%- endfor %}
{%- endfor %}

    
- type: epics.PostStartupCommand 
  command: |
  {%- for dev in devices %}
  {%- for param in dev.iocinit %}
  dbpf ("{{iocprefix}}:{{dev.name}}:{{param.name}}","{{param.value}}")
  {%- endfor %}
  {%- endfor %}
  {%- if iocexit %}
      dbl
      exit
  {%- else %}
      dbl("*") > {{config_dir}}/pvlist.txt           ## dumps PV NAMES
      dbl
  {%- endif %}

  