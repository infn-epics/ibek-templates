
ioc_name: {{iocname}}
description: sigmaPhiStart 

entities:

  - type: sigmaPhiStart.configure
    controllerName: START
    P: {{iocprefix}}
    IP: {{server}}
    TCPPORT: {{port | default(502) }}

{%- set ioc_ps = (ps if ps is defined else {}) %}
{%- for t in devices %}
{%- set dev_ps = t.get('ps', {}) %}
  # NOTE: no fallback numeric default on purpose (matches original template
  # behavior, which had none either) - this is a hardware current limit, and
  # a silently-wrong default is worse than a loud failure if ps.current.max
  # was never set for this device.
  - type: sigmaPhiStart.device
    controller: START
    P: {{t.name}}
    max: {{dev_ps.get('current', {}).get('max', ioc_ps.get('current', {}).get('max', none)) }}
{%- endfor %}


  - type: epics.PostStartupCommand 
    command: |
  {%- for dev in devices %}
  {%- for param in dev.iocinit %}
      dbpf ("{{iocprefix}}:{{dev.name}}:{{param.name}}","{{param.value}}")
  {%- endfor %}
  {%- endfor %}
  {%- if iocexit %}
      dbl
      exit
  {%- else %}
      dbl("*") > {{config_dir}}/pvlist.txt           ## dumps PV NAMES
      dbl
  {%- endif %}