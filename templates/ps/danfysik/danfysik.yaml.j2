ioc_name: {{iocname}}
description: DANFYSIK SYS8X00 TEMPLATE

entities:
# ============================================================================
# TCP/IP Connection
# ============================================================================
- type: danfysik.tcp
  NAME: "DANFYSIK_PORT"
  IP: {{ server if server is defined else "192.168.1.100" }}
  PORT: {{ port if port is defined else 4001 }}

# ============================================================================
# Power Supplies with UNIMAG Interfaces
# ============================================================================
{%- set ioc_ps = (ps if ps is defined else {}) %}
{%- for device in devices %}
{%- set dev_ps = device.get('ps', {}) %}
- type: danfysik.ps
  NAME: "{{device.name}}"
  P: "{{iocprefix}}:{{device.name}}"
  PORT: "DANFYSIK_PORT"
  ADDR: {{ device.id }}
  # NOTE: device.ps.polarity is informational only here - the danfysik.ps IBEK
  # entity has no signed-polarity input today. Do not add one without first
  # confirming the entity's parameter schema in the danfysik ibek-support package.
  IMAX: {{ dev_ps.get('current', {}).get('max', ioc_ps.get('current', {}).get('max', 100.0)) }}
  VMAX: {{ dev_ps.get('voltage', {}).get('max', ioc_ps.get('voltage', {}).get('max', 25.0)) }}
  PREC: 3
  unimag_enable: {{ device.unimag_enable | default(true) }}
  debug: {{ device.debug | default(1) }}
{%- endfor %}

# ============================================================================
# POST-STARTUP COMMANDS
# ============================================================================
- type: epics.PostStartupCommand
  command: |
    # Initialize the power supplies for remote operation
    epicsThreadSleep 2.0
    {%- for device in devices %}
    dbpf "{{iocprefix}}:{{device.name}}:INIT_REMOTE" 1
    dbpf "{{iocprefix}}:{{device.name}}:ERROR_TEXT" 1
    {%- endfor %}
  {%- if iocexit %}
    dbl
    exit
  {%- else %}
    dbl("*") > {{config_dir}}/pvlist.txt
    dbl
  {%- endif %}