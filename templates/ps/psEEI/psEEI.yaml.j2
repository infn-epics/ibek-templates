ioc_name: {{iocname}}
description: EEI Power Supply TEMPLATE

entities:
# ============================================================================
# TCP/IP MODE - Direct Modbus TCP connection per device
# ============================================================================
{%- set ioc_ps = (ps if ps is defined else {}) %}
{%- for t in devices %}
{%- set dev_ps = t.get('ps', {}) %}

- type: EEI.ps
  IP: {{ t.ip }}
  TCPPORT: {{ port if port is defined else 502 }}
  P: "{{ iocprefix }}"
  R: "{{ t.name }}"
  SLAVE_ID: {{ t.slave_id if t.slave_id is defined else 1 }}
  RPOLL: {{ t.rpoll if t.rpoll is defined else 1000 }}
  WPOLL: {{ t.wpoll if t.wpoll is defined else 0 }}
  TIMEOUT: {{ t.timeout if t.timeout is defined else 1000 }}
  MAX_CURR: {{ dev_ps.get('current', {}).get('max', ioc_ps.get('current', {}).get('max', 330000)) }}
  MIN_CURR: {{ dev_ps.get('current', {}).get('min', ioc_ps.get('current', {}).get('min', -330000)) }}
  SW_MODE: {{ t.sw_mode if t.sw_mode is defined else 1 }}
  POLARITY_VIA_SIGN: {{ 1 if dev_ps.get('polarity', {}).get('mode', ioc_ps.get('polarity', {}).get('mode', '')) in ['bipolar-native','bipolar-switched'] else 0 }}

{%- endfor %}

# ============================================================================
# POST-STARTUP COMMANDS
# ============================================================================

# --- Aliases (currently disabled) ---
# - type: epics.StartupCommand
#   command: |
#     echo "Starting {{iocname}} IOC"
#     {%- for dev in devices %}
#     {%- for param in dev.aliases %}
#     alias("{{iocprefix}}:{{dev.name}}:{{param.name}}","{{param.alias}}")
#     {%- endfor %}
#     {%- endfor %}

# --- Initialize PV values ---
# RAMP_RATE_SET has no db-level default and resets to 0 on every IOC
# restart, so a device is silently un-ramped until someone sets it. There's
# no safe universal default (it varies per magnet), so set `ps.current.ramp`
# (device-level or IOC-level) on a device below to have it applied
# automatically at startup; devices that don't set it are unaffected (same
# as before this was added, when the field was named `ramp_rate`).
- type: epics.PostStartupCommand
  command: |
  {%- for param in iocinit %}
    dbpf("{{iocprefix}}:{{iocroot}}:{{param.name}}", "{{param.value}}")
  {%- endfor %}
  {%- set ioc_ps2 = (ps if ps is defined else {}) %}
  {%- for dev in devices %}
  {%- set ramp = dev.get('ps', {}).get('current', {}).get('ramp', ioc_ps2.get('current', {}).get('ramp', none)) %}
  {%- if ramp is not none %}
    dbpf("{{iocprefix}}:{{dev.name}}:RAMP_RATE_SET", "{{ramp}}")
  {%- endif %}
  {%- for param in dev.iocinit %}
    dbpf("{{iocprefix}}:{{dev.name}}:{{param.name}}", "{{param.value}}")
  {%- endfor %}
  {%- endfor %}
  {%- if iocexit %}
    dbl
    exit
  {%- else %}
    dbl("*") > {{config_dir}}/pvlist.txt
    dbl
  {%- endif %}
