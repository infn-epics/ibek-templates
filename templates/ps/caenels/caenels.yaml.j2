ioc_name: {{iocname}}
description: Caenels template {{devtype}}

entities:
{%- set ioc_ps = (ps if ps is defined else {}) %}
{%- for alim in devices %}
{%- set dev_ps = alim.get('ps', {}) %}
  - type: caenels.{{devtype}}
    P: "{{iocprefix}}:"
    R: "{{alim.name}}:"
    IP: {{alim.ip}}
    TCPPORT: {{alim.port | default(10001)}}
{%- if devtype == "fastps" %}
    rangeI: {{dev_ps.get('current', {}).get('max', ioc_ps.get('current', {}).get('max', 30))}}
    rangeV: {{dev_ps.get('voltage', {}).get('max', ioc_ps.get('voltage', {}).get('max', 20))}}
    rampI: {{dev_ps.get('current', {}).get('ramp', ioc_ps.get('current', {}).get('ramp', 0))}}
    rampV: {{dev_ps.get('voltage', {}).get('ramp', ioc_ps.get('voltage', {}).get('ramp', 0))}}
{%- else %}
    range: {{dev_ps.get('current', {}).get('max', ioc_ps.get('current', {}).get('max', 30))}}
{%- endif %}
    # OMAX/IMAX are an additional software safety clamp layered on top of
    # range/rangeI, independent of it (0 = disabled, matching prior behavior).
    # No polarity parameter exists on this entity - ps.polarity stays informational.
    OMAX: {{dev_ps.get('voltage', {}).get('limit', ioc_ps.get('voltage', {}).get('limit', 0))}}
    IMAX: {{dev_ps.get('current', {}).get('limit', ioc_ps.get('current', {}).get('limit', 0))}}
{%- endfor %}


{%- for dev in devices %}

{%- for param in dev.aliases %}
  - type: epics.DbAlias
    name: "{{iocprefix}}:{{iocroot}}:{{param.name}}"
    alias: "{{iocprefix}}:{{iocroot}}:{{param.alias}}"
{%- endfor %}
{%- endfor %}
  

  - type: epics.PostStartupCommand 
    command: |
  {%- for param in iocinit %}
      dbpf ("{{iocprefix}}:{{iocroot}}:{{param.name}}","{{param.value}}")
  {%- endfor %}
  {%- for dev in devices %}
  {%- for param in dev.iocinit %}
      dbpf ("{{iocprefix}}:{{dev.name}}:{{param.name}}","{{param.value}}")
  {%- endfor %}
  {%- endfor %}
  {%- if iocexit %}
      dbl
      exit
  {%- else %}
      dbl("*") > {{config_dir}}/pvlist.txt           ## dumps PV NAMES
      dbl
  {%- endif %}