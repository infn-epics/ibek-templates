ioc_name: {{iocname}}
description: OCEM template {{devtype}}

entities:
{% if devtype == "modbusps" %}
{%- set ioc_ps = (ps if ps is defined else {}) %}
{%- for alim in devices %}
{%- set dev_ps = alim.get('ps', {}) %}
  - type: ocem.modbusps
    P: "{{iocprefix}}"
    R: "{{alim.name}}"
    IP: {{alim.ip}}
    IMAX: {{dev_ps.get('current', {}).get('max', ioc_ps.get('current', {}).get('max', 100))}}
    VMAX: {{dev_ps.get('voltage', {}).get('max', ioc_ps.get('voltage', {}).get('max', 16))}}
    TCPPORT: {{alim.port | default(502)}}
    CORRECTION: {{alim.correction | default(1.8)}}  
    CORRECTIONSET: {{alim.correctionset | default(1)}} 
{%- endfor %}
{%- endif %}

{% if devtype == "modbusps4chan" %}
{%- set ioc_ps = (ps if ps is defined else {}) %}
  - type: ocem.modbusps4chan
    P: "{{iocprefix}}"
    R: "{{cratename}}"
    IP: {{ip}}
    IMAX: {{ioc_ps.get('current', {}).get('max', 30)}}
    VMAX: {{ioc_ps.get('voltage', {}).get('max', 16)}}
    TCPPORT: {{port | default(502)}}
{% set ways = ["WAYA", "WAYB", "WAYC", "WAYD"] %}
{%- for alim in devices %}
{%- set way = ways[loop.index0] %}
{% if alim.name %}
  - type: epics.DbAlias
    name: "{{iocprefix}}:{{cratename}}:{{way}}:CURRENT_RB"
    alias: "{{iocprefix}}:{{alim.name}}:CURRENT_RB"
  - type: epics.DbAlias
    name: "{{iocprefix}}:{{cratename}}:{{way}}:CURRENT_SP"
    alias: "{{iocprefix}}:{{alim.name}}:CURRENT_SP"
  - type: epics.DbAlias
    name: "{{iocprefix}}:{{cratename}}:{{way}}:STATE_SP"
    alias: "{{iocprefix}}:{{alim.name}}:STATE_SP"
  - type: epics.DbAlias
    name: "{{iocprefix}}:{{cratename}}:{{way}}:STATE_RB"
    alias: "{{iocprefix}}:{{alim.name}}:STATE_RB"

  - type: epics.DbLine
    line: 'record(stringin, \"{{iocprefix}}:{{alim.name}}:PARENT\") {'

  - type: epics.DbLine
    line: '    field(VAL, \"{{iocprefix}}:{{cratename}}\")'

  - type: epics.DbLine
    line: '    field(PINI, \"YES\")'

  - type: epics.DbLine
    line: '}'
    
{%- endif %}    
{%- endfor %}

{%- endif %}



{% if devtype == "E642" %}

  # Controller entity
  - type: ocem.E642Group
    P: "{{iocprefix}}"
    NAME: "{{name}}"
    IP: "{{server}}"
    TCPPORT: {{port | default(502)}}
    SLAVELIST: "{{devices | map(attribute='id') | join(',') }}"
    INIT_TIMEOUT_S: {{init_timeout_s | default(5.0)}}
    INIT_MAX_RETRIES: {{init_max_retries | default(3)}}
    IDLE_POLL_S: {{idle_poll_s | default(0.2)}}
    ACTIVE_POLL_S: {{active_poll_s | default(0.1)}}
    ACTIVE_TIMEOUT_S: {{active_timeout_s | default(5.0)}}
    DEBUG_LEVEL: {{debug_level | default(0)}}

  # Slave entities
  {%- set ioc_ps = (ps if ps is defined else {}) %}
  {%- for sl in devices %}
  {%- set dev_ps = sl.get('ps', {}) %}
  - type: ocem.E642
    P: "{{iocprefix}}"
    R: "{{sl.name}}"
    NAME: "{{name}}"
    ADDR: {{sl.id}}
    IMAX: {{dev_ps.get('current', {}).get('max', ioc_ps.get('current', {}).get('max', 280))}}
    VMAX: {{dev_ps.get('voltage', {}).get('max', ioc_ps.get('voltage', {}).get('max', 40))}}
    SET_TOLERANCE: {{sl.set_tolerance | default(set_tolerance) | default(1.8)}}
    ZERO_TOLERANCE: {{sl.zero_tolerance | default(zero_tolerance) | default(1.8)}}
    SET_TIMEOUT_S: {{sl.set_timeout_s | default(set_timeout_s) | default(60.0)}}
    INIT_TIMEOUT_S: {{sl.init_timeout_s | default(init_timeout_s) | default(60.0)}}
    CURRENT_THRESHOLD: {{sl.current_threshold | default(current_threshold) | default(99999)}}
    VOLTAGE_THRESHOLD: {{sl.voltage_threshold | default(voltage_threshold) | default(999)}}
    POLL_STATE: {{sl.poll_state | default(poll_state) | default(1)}}
    POLL_STATE_INTERVAL: {{sl.poll_state_interval | default(poll_state_interval) | default(1.0)}}
    POLL_ANALOG: {{sl.poll_analog | default(poll_analog) | default(1)}}
    POLL_ANALOG_INTERVAL: {{sl.poll_analog_interval | default(poll_analog_interval) | default(0.5)}}
  {%- endfor %}


{% endif %}

  - type: epics.PostStartupCommand 
    command: |
  {%- for param in iocinit %}
      dbpf ("{{iocprefix}}:{{iocroot}}:{{param.name}}","{{param.value}}")
  {%- endfor %}
  {%- for dev in devices %}
  {%- for param in dev.iocinit %}
      dbpf ("{{iocprefix}}:{{dev.name}}:{{param.name}}","{{param.value}}")
  {%- endfor %}
  {%- endfor %}
  {%- if iocexit %}
      dbl
      exit
  {%- else %}
      dbl("*") > {{config_dir}}/pvlist.txt           ## dumps PV NAMES
      dbl
  {%- endif %}
