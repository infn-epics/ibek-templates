ioc_name: {{iocname}}
description: Bergoz BCM-RF-E Beam Charge Monitor

# Uses the native bcmAsynMon driver over TCP/IP.
# The driver manages the connection and protocol parsing internally.
#
# TCP/IP example:
#   server: 192.168.1.100
#   port: 4001            # optional, default 4001
#   reconnect_ms: 1000    # optional, default 1000
#   iocprefix: BCM:RF:01
#   scan: ".2 second"     # optional, default ".2 second"
#
# Optional aliases:
#   aliases:
#     - name: CHARGE
#       alias: CHARGE_RB

{%- set _scan         = scan         | default(".2 second", true) %}
{%- set _reconnect_ms = reconnect_ms | default(1000, true) %}
{%- set _pname = iocname | replace("-", "_") | replace(":", "_") | upper %}

entities:

  - type: bergozBcm.ipDevice
    NAME: "{{_pname}}_PORT"
    P: "{{iocprefix}}"
    HOST: "{{server}}"
    TCPPORT: {{ port | default(4001, true) }}
    RECONNECT_MS: {{_reconnect_ms}}
    SCAN: "{{_scan}}"

{%- if aliases is defined and aliases %}
{%- for param in aliases %}
  - type: epics.DbAlias
    name: "{{iocprefix}}:{{param.name}}"
    alias: "{{iocprefix}}:{{param.alias}}"
{%- endfor %}
{%- endif %}

  - type: epics.PostStartupCommand
    command: |
      dbl("*") > {{config_dir | default("/config")}}/pvlist.txt
      dbl
